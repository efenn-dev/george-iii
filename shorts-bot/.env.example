# ============================================================
# Shorts Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================


# ─────────────────────────────────────────────
# DISCORD
# ─────────────────────────────────────────────

# Your Discord bot token.
# How to get it:
#   1. Go to https://discord.com/developers/applications
#   2. Create a new application (or select an existing one).
#   3. Go to "Bot" → click "Add Bot" → copy the Token.
#   4. Under "Privileged Gateway Intents", enable:
#        - Message Content Intent
#        - Server Members Intent (optional but recommended)
#   5. Invite the bot to your server:
#        Go to OAuth2 → URL Generator → select "bot" scope and these permissions:
#          Send Messages, Attach Files, Add Reactions, Read Message History, Embed Links
#        Open the generated URL in a browser and add the bot to your server.
DISCORD_BOT_TOKEN=

# The numeric ID of the Discord channel where videos will be posted for approval.
# How to get it:
#   1. In Discord, go to User Settings → Advanced → enable "Developer Mode".
#   2. Right-click the target channel → "Copy Channel ID".
DISCORD_CHANNEL_ID=

# The numeric ID of the Discord user who is authorized to approve/reject videos.
# How to get it:
#   With Developer Mode enabled, right-click your username → "Copy User ID".
DISCORD_AUTHORIZED_USER_ID=


# ─────────────────────────────────────────────
# YOUTUBE
# ─────────────────────────────────────────────

# Path to your Google OAuth2 client secrets JSON file.
# How to get it:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project (or select one).
#   3. Enable the "YouTube Data API v3":
#        APIs & Services → Enable APIs → search "YouTube Data API v3" → Enable.
#   4. Create OAuth credentials:
#        APIs & Services → Credentials → Create Credentials → OAuth client ID.
#        Application type: Desktop app.
#        Download the JSON file and save it next to this project (e.g. client_secrets.json).
#   5. Set this to the filename/path of that JSON file.
# On first run, a browser window will open for you to authorize the app.
# The token is saved to token.json automatically for future runs.
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json


# ─────────────────────────────────────────────
# TIKTOK (optional — not yet implemented)
# ─────────────────────────────────────────────

# TikTok Content Posting API access token.
# How to get it:
#   1. Register at https://developers.tiktok.com/
#   2. Create an app and enable the "Content Posting API" product.
#   3. Complete the OAuth2 flow to obtain an access token.
#   4. Note: Production video posting requires TikTok app review.
# See uploaders/tiktok.py for full implementation instructions.
TIKTOK_ACCESS_TOKEN=


# ─────────────────────────────────────────────
# INSTAGRAM (optional — not yet implemented)
# ─────────────────────────────────────────────

# Instagram Graph API long-lived user access token.
# How to get it:
#   1. Create a Facebook Developer account: https://developers.facebook.com/
#   2. Create a Facebook App and add the "Instagram Graph API" product.
#   3. Connect an Instagram Professional (Business or Creator) account to a Facebook Page.
#   4. Generate a User Access Token with these permissions:
#        instagram_basic, instagram_content_publish, pages_read_engagement
#   5. Exchange for a long-lived token (60-day expiry; must be refreshed periodically).
# See uploaders/instagram.py for full implementation instructions.
INSTAGRAM_ACCESS_TOKEN=

# Your numeric Instagram User ID (not your username).
# How to get it:
#   Call: GET https://graph.facebook.com/v18.0/me?fields=id,name&access_token=<your_token>
#   Or use the Graph API Explorer at https://developers.facebook.com/tools/explorer/
INSTAGRAM_USER_ID=
